############################################
# APP
############################################
APP_NAME=LUMIÈRE
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://lumiere.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Comma-separated list of previous APP_KEYs, used during key rotation
APP_PREVIOUS_KEYS=

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Frontend origin allowed by CORS + used to scope Sanctum stateful domains
FRONTEND_URL=https://lumiere.app

############################################
# LOGGING
############################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
LOG_DAILY_DAYS=14

# Only needed if LOG_CHANNEL/LOG_STACK includes these drivers
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_USERNAME="Laravel Log"
LOG_SLACK_EMOJI=":boom:"
LOG_PAPERTRAIL_HANDLER=monolog
LOG_STDERR_FORMATTER=
LOG_SYSLOG_FACILITY=user
PAPERTRAIL_URL=
PAPERTRAIL_PORT=

############################################
# DATABASE (MySQL in production)
############################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lumiere
DB_USERNAME=root
DB_PASSWORD=

DB_URL=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SOCKET=
DB_SSLMODE=
DB_ENCRYPT=
DB_TRUST_SERVER_CERTIFICATE=
DB_FOREIGN_KEYS=true
MYSQL_ATTR_SSL_CA=

############################################
# SESSION
############################################
SESSION_DRIVER=database
SESSION_STORE=
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave blank for single-domain; set to .lumiere.app for cross-subdomain tenant sessions
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false
SESSION_TABLE=sessions
SESSION_CONNECTION=

SANCTUM_TOKEN_PREFIX=

############################################
# CACHE
############################################
CACHE_STORE=database
CACHE_PREFIX=

DB_CACHE_CONNECTION=
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_CONNECTION=
DB_CACHE_LOCK_TABLE=

############################################
# QUEUE
############################################
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

DB_QUEUE_CONNECTION=
DB_QUEUE=default
DB_QUEUE_TABLE=jobs
DB_QUEUE_RETRY_AFTER=90

BEANSTALKD_QUEUE_HOST=localhost
BEANSTALKD_QUEUE=default
BEANSTALKD_QUEUE_RETRY_AFTER=90

SQS_PREFIX=
SQS_QUEUE=default
SQS_SUFFIX=

############################################
# REDIS (only if used for cache/session/queue)
############################################
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_USERNAME=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CLUSTER=redis
REDIS_PREFIX=
REDIS_URL=
REDIS_PERSISTENT=false
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=
REDIS_QUEUE_RETRY_AFTER=90
REDIS_CACHE_CONNECTION=
REDIS_CACHE_LOCK_CONNECTION=

############################################
# MEMCACHED (only if CACHE_STORE=memcached)
############################################
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_PERSISTENT_ID=

############################################
# FILESYSTEM / STORAGE
############################################
# Local dev: public   |   Production: cloudinary
# Controllers call ->store() with no disk name, so switching this one value
# moves every upload (products, gallery, profile photos) between local and Cloudinary.
FILESYSTEM_DISK=public

# Only needed if using the S3 disk
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

############################################
# CLOUDINARY (used for image/media uploads)
############################################
CLOUDINARY_URL=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UPLOAD_ROUTE=
CLOUDINARY_UPLOAD_ACTION=
CLOUDINARY_NOTIFICATION_URL=

############################################
# MAIL
############################################
MAIL_MAILER=smtp
MAIL_SCHEME=
MAIL_URL=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_EHLO_DOMAIN=
MAIL_FROM_ADDRESS="hello@lumiere.app"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_LOG_CHANNEL=
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"

# Only needed if MAIL_MAILER=postmark
POSTMARK_API_KEY=
POSTMARK_MESSAGE_STREAM_ID=

# Only needed if MAIL_MAILER=resend
RESEND_API_KEY=

############################################
# RAZORPAY (subscription billing)
############################################
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

############################################
# TWILIO (WhatsApp appointment reminders — optional, currently commented in code)
############################################
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=

############################################
# BACKUP (spatie/laravel-backup)
############################################
BACKUP_ARCHIVE_PASSWORD=

############################################
# SLACK (optional notification channel)
############################################
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

############################################
# AUTH
############################################
AUTH_GUARD=web
